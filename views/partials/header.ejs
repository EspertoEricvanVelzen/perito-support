<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo-link">
      <img src="/images/logo-kleur.svg" alt="Perito Professional Performance" class="logo">
    </a>
    <nav class="main-nav" id="mainNav">
      <a href="/kennismaking" class="<%= currentPath === '/kennismaking' ? 'active' : '' %>">Kennismaking</a>
      <a href="/instrumenten" class="<%= currentPath.startsWith('/instrumenten') ? 'active' : '' %>">Instrumenten</a>
      <a href="/ledenbeheer" class="<%= currentPath === '/ledenbeheer' ? 'active' : '' %>">Ledenbeheer</a>
      <a href="/faq" class="<%= currentPath === '/faq' ? 'active' : '' %>">FAQ</a>
      <a href="/videos" class="<%= currentPath === '/videos' ? 'active' : '' %>">Video's</a>
      <a href="/contact" class="<%= currentPath === '/contact' ? 'active' : '' %>">Contact</a>
    </nav>
    <div class="header-actions">
      <button class="search-toggle" id="searchToggle" aria-label="Zoeken">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </button>
      <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>
  </div>
  <!-- Search overlay -->
  <div class="search-overlay" id="searchOverlay">
    <div class="container">
      <form class="search-form-header" action="/zoeken" method="GET">
        <input type="text" name="q" placeholder="Waar zoekt u naar?" class="search-input-header" id="searchInputHeader" autocomplete="off">
        <button type="submit" class="search-submit">Zoeken</button>
        <button type="button" class="search-close" id="searchClose">&times;</button>
      </form>
      <div class="search-suggestions" id="searchSuggestions"></div>
    </div>
  </div>
</header>
