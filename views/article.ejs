<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title %> — Perito Support</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/images/logo-kleur.svg">
</head>
<body>
  <%- include('partials/header') %>
  <main class="site-main">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <% if (typeof parentBreadcrumb !== 'undefined' && parentBreadcrumb) { %>
          <span class="breadcrumb-sep">/</span>
          <a href="<%= parentBreadcrumb.url %>"><%= parentBreadcrumb.title %></a>
        <% } %>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current"><%= breadcrumb %></span>
      </nav>
      <article class="article-content">
        <%- page.html %>
      </article>
    </div>
  </main>
  <%- include('partials/footer') %>
  <script src="/js/search.js"></script>
</body>
</html>
